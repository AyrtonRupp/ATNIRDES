<div class="contactenos-box" id="contactenos">
    <div class="contact" id="contact">
        <h1>Contáctanos</h1>
        <form id="contactForm" action="https://formsubmit.co/ayrtonalexanderupp@gmail.com" method="POST">
            <label for="name">Nombre:</label>
            <input type="text" id="name" name="name" placeholder="Ingresa tu nombre" required>

            <label for="email">Correo Electrónico:</label>
            <input type="email" id="email" name="email" placeholder="Ingresa tu correo" required>

            <label for="phone">Teléfono:</label>
            <input type="tel" id="phone" name="phone" placeholder="Ejemplo: 123-456-7890" required>

            <label for="message">Mensaje:</label>
            <textarea id="message" name="message" rows="5" placeholder="Escribe tu mensaje aquí"></textarea>

            <button type="submit" class="btn">Enviar</button>
        </form>
    </div>
</div>

<div id="confirmationModal" class="modal hidden">
    <div class="modal-content">
        <h2>¡Gracias por contactarnos!</h2>
        <p>Pronto uno de nuestros operadores se pondrá en contacto contigo. Nos esforzamos por responder lo más rápido posible.</p>
        <button id="closeModal" class="btn">Cerrar</button>
    </div>
</div>

<style>
    /* Modal */
    .modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.6);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
        visibility: hidden;
        opacity: 0;
        transition: visibility 0s, opacity 0.3s ease-in-out;
    }
    
    .modal-content {
        background-color: rgba(130, 28, 111, 0.9); /* Fondo púrpura intenso */
        color: #FFFFFF;
        padding: 30px;
        border-radius: 8px;
        text-align: center;
        max-width: 400px;
        width: 90%;
        box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.2);
        font-family: 'Heebo', sans-serif;
    }
    
    .modal-content h2 {
        color: #FFD1E8; /* Tono púrpura claro */
        margin-bottom: 20px;
    }
    
    .modal-content button {
        background-color: #FFD1E8; /* Botón púrpura claro */
        color: #831C6F; /* Texto púrpura oscuro */
        border: none;
        padding: 10px 20px;
        cursor: pointer;
        font-weight: bold;
        border-radius: 4px;
        font-family: 'Heebo', sans-serif;
    }
    
    .modal-content button:hover {
        background-color: rgba(130, 28, 111, 0.8);
    }
    
    .modal.show {
        visibility: visible;
        opacity: 1;
    }
    
    /* Formulario */
    .contactenos-box {
        background: linear-gradient(to bottom right, rgba(130, 28, 111, 0.8), rgba(180, 50, 150, 0.7));
        padding: 20px;
    }
    
    .contact {
        background: rgba(130, 28, 111, 0.5); /* Fondo púrpura semitransparente */
        backdrop-filter: blur(10px);
        color: #FFFFFF;
        padding: 30px;
        border-radius: 8px;
        max-width: 500px;
        margin: 0 auto;
        font-family: 'Heebo', sans-serif;
    }
    
    .contact h1 {
        color: #FFD1E8; /* Texto púrpura claro */
        text-align: center;
        margin-bottom: 20px;
        font-size: 2rem;
    }
    
    .contact label {
        display: block;
        margin-bottom: 8px;
        color: #F2F2F2; /* Blanco tenue */
        font-family: 'Heebo', sans-serif;
    }
    
    .contact input,
    .contact textarea,
    .contact button {
        width: 100%;
        padding: 12px;
        margin-bottom: 15px;
        border: 1px solid #FFD1E8; /* Borde púrpura claro */
        border-radius: 4px;
        font-size: 14px;
        box-sizing: border-box;
        font-family: 'Heebo', sans-serif;
        color: #831C6F; /* Texto púrpura oscuro */
    }
    
    .contact textarea {
        resize: none;
        height: 120px;
    }
    
    .contact button,
.modal-content button {
    background-color: #FFD1E8; /* Botón púrpura claro */
    color: #831C6F; /* Texto púrpura oscuro */
    border: none;
    padding: 10px 20px;
    cursor: pointer;
    font-weight: bold;
    font-family: 'Heebo', sans-serif;
    border-radius: 4px;
    transition: background-color 0.3s ease, color 0.3s ease;
}

.contact button:hover,
.modal-content button:hover {
    background-color: #831C6F; /* Fondo púrpura oscuro */
    color: #FFFFFF; /* Texto blanco */
}
    
    /* Responsivo */
    @media (max-width: 600px) {
        .contact {
            padding: 20px;
        }
    
        .contact h1 {
            font-size: 1.5rem;
        }
    
        .modal-content {
            padding: 20px;
        }
    }
    </style>
    
    <script>
    const form = document.getElementById('contactForm');
    const modal = document.getElementById('confirmationModal');
    const closeModal = document.getElementById('closeModal');
    
    // Mostrar el modal cuando se envíe el formulario
    form.addEventListener('submit', function () {
        modal.classList.add('show');
    });
    
    // Cerrar el modal al hacer clic en el botón de cerrar
    closeModal.addEventListener('click', function () {
        modal.classList.remove('show');
    });
    </script>
    